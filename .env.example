DATABASE_URL="postgresql://user:password@localhost:5432/ai_agents_db"
JWT_SECRET="your-secret-key-change-in-production"
PORT=3001
FRONTEND_URL="http://localhost:5173"
VITE_API_URL="/api"
VITE_UMAMI_SCRIPT_URL=""
VITE_UMAMI_WEBSITE_ID=""
VITE_GA4_MEASUREMENT_ID=""
VITE_GOOGLE_SITE_VERIFICATION=""
VITE_CLARITY_PROJECT_ID=""
VITE_HOTJAR_SITE_ID=""
VITE_HOTJAR_VERSION=6
VITE_META_PIXEL_ID=""

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Facebook OAuth (create app at https://developers.facebook.com/)
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# Sign in with Apple (Services ID, Team ID, Key ID, and private key from Apple Developer)
APPLE_CLIENT_ID="com.yourapp.service"
APPLE_TEAM_ID="your-team-id"
APPLE_KEY_ID="your-key-id"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# JWT refresh/session
JWT_REFRESH_SECRET="your-refresh-secret-key"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET="your-session-secret-key"

# OAuth callback URLs
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/facebook/callback
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback
APPLE_PRIVATE_KEY_LOCATION=./certs/apple-private-key.p8
APPLE_CALLBACK_URL=http://localhost:3001/api/auth/apple/callback
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_CALLBACK_URL=http://localhost:3001/api/auth/linkedin/callback

# Email, magic link, OTP, visitor alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM=noreply@aiagentspro.in
ALERT_EMAIL=admin@aiagentspro.in
ALERT_WHATSAPP_NUMBER="+91XXXXXXXXXX"

# Frontend runtime URLs
VITE_SOCKET_URL=""

# GOOGLE: https://console.cloud.google.com -> APIs & Services -> Credentials -> Create OAuth 2.0 Client
# Add authorized redirect: http://localhost:3001/api/auth/google/callback
# Add production redirect: https://aiagentspro.in/api/auth/google/callback
# FACEBOOK: https://developers.facebook.com -> My Apps -> Create App -> Facebook Login
# Add OAuth redirect: http://localhost:3001/api/auth/facebook/callback
# GITHUB: https://github.com/settings/applications/new
# Homepage URL: http://localhost:5173
# Callback: http://localhost:3001/api/auth/github/callback
# APPLE: https://developer.apple.com -> Certificates, IDs & Profiles -> Services IDs
# Requires paid Apple Developer account and an HTTPS domain.
# LINKEDIN: https://www.linkedin.com/developers/apps/new
# Add redirect: http://localhost:3001/api/auth/linkedin/callback
# ALERT_EMAIL: set to your admin notification inbox.
# SMTP setup: use a Gmail App Password, not your main password.
