// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  password             String?
  phone                String?
  company              String?
  role                 Role                  @default(USER)
  googleId             String?               @unique
  githubId             String?               @unique
  facebookId           String?               @unique
  appleId              String?               @unique
  linkedinId           String?               @unique
  avatar               String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  passwordResetTokens  PasswordResetToken[]
  magicLinkTokens      MagicLinkToken[]
  posts                Post[]
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
  @@index([authorId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Visitor {
  id          String   @id @default(cuid())
  sessionId   String
  ip          String   @default("unknown")
  page        String
  city        String   @default("Unknown")
  region      String   @default("")
  country     String   @default("Unknown")
  timezone    String   @default("")
  browser     String   @default("Unknown")
  os          String   @default("Unknown")
  device      String   @default("desktop")
  deviceModel String   @default("")
  referrer    String   @default("direct")
  language    String   @default("unknown")
  timestamp   DateTime @default(now())

  @@index([sessionId])
  @@index([timestamp])
  @@index([country])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  source    String?
  pagePath  String?
  message   String
  createdAt DateTime @default(now())
  status    Status   @default(PENDING)

  @@index([createdAt])
  @@index([status])
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float?
  features    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id                     String     @id @default(cuid())
  fullName               String
  email                  String
  phone                  String?
  companyName            String
  companyWebsite         String?
  industry               String?
  companySize            String?
  primaryGoal            String
  currentTools           String[]
  conversationVolume     String?
  biggestChallenge       String
  preferredContactMethod String?
  message                String?
  status                 LeadStatus @default(NEW)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([email])
}

enum Role {
  USER
  ADMIN
}

enum Status {
  PENDING
  RESOLVED
  SPAM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}
